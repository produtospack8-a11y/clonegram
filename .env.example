# Copie para .env.local (dev local, nunca commitar):
#   cp .env.example .env.local
#
# Token: https://console.apify.com/account/integrations
# APIFY_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Em .env (pode commitar — sem segredos):
VITE_APIFY_ENABLED=true

# Opcional — actor de perfil Instagram
# VITE_APIFY_ACTOR_ID=instagram-scraper~instagram-profile-scraper

# Vercel (Project → Settings → Environment Variables):
#   APIFY_TOKEN          — Production, Preview, Development (sem prefixo VITE_)
#   VITE_APIFY_ENABLED   — true
#   VITE_APIFY_ACTOR_ID  — opcional (ver acima)
